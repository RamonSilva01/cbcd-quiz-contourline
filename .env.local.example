# ============ Supabase (obrigatório) ============
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============ Admin ============
# E-mail(s) com permissão de acesso ao /admin — separados por vírgula.
# Qualquer operadora da Contourline com essa permissão pode logar por magic link.
ADMIN_ALLOWED_EMAILS=marketing@contourline.com.br

# ============ Raffle ============
# Senha compartilhada para ação de sorteio (camada extra além do login)
RAFFLE_ADMIN_PIN=mudar-antes-do-evento

